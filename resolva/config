"""
Per-user configuration for Resolva.

Same philosophy as the CSR Automation Toolkit reference: no `.env` file.
Each operator/SME enters their own credentials through the in-app Settings
page. Everything here is OPTIONAL — Resolva runs fully offline (rule-based
classification + raw-text passthrough + CSV/SQLite logging) with every field
left blank.

The config file, the knowledge-base database, and the audit log all live in
the per-user data directory (NOT next to the packaged .exe), so they survive
app updates and are never bundled into the executable.
"""

import os
import sys
import json
from pathlib import Path


def data_dir() -> Path:
    """Per-user, per-OS data directory. Created on first access."""
    if sys.platform == "win32":
        base = Path(os.getenv("APPDATA", Path.home()))
    elif sys.platform == "darwin":
        base = Path.home() / "Library" / "Application Support"
    else:
        base = Path.home() / ".config"
    d = base / "Resolva"
    d.mkdir(parents=True, exist_ok=True)
    return d


def config_path() -> Path:
    return data_dir() / "config.json"


def db_path() -> Path:
    return data_dir() / "resolva_kb.sqlite3"


def audit_path() -> Path:
    return data_dir() / "resolva_audit.csv"


# Defaults applied when a key is missing from the saved config.
DEFAULTS = {
    "ANTHROPIC_API_KEY": "",
    "ANTHROPIC_MODEL": "claude-sonnet-4-6",
    "SLACK_WEBHOOK_URL": "",
    # Salt used to turn a source CRM id into the internal 6-digit account
    # number. Generated once per install so the mapping is stable on this
    # machine but not portable/guessable. Never leaves this file.
    "ACCOUNT_SALT": "",
}


def load() -> dict:
    cfg = dict(DEFAULTS)
    p = config_path()
    if p.exists():
        try:
            cfg.update(json.loads(p.read_text(encoding="utf-8")))
        except (json.JSONDecodeError, OSError):
            pass
    # Lazily create a per-install salt the first time we load.
    if not cfg.get("ACCOUNT_SALT"):
        cfg["ACCOUNT_SALT"] = os.urandom(16).hex()
        save(cfg)
    return cfg


def save(cfg: dict) -> None:
    config_path().write_text(json.dumps(cfg, indent=2), encoding="utf-8")


# Convenience flags ---------------------------------------------------------

def ai_enabled(cfg: dict) -> bool:
    return bool(cfg.get("ANTHROPIC_API_KEY"))


def slack_enabled(cfg: dict) -> bool:
    return bool(cfg.get("SLACK_WEBHOOK_URL"))